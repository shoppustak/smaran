# Required — server throws on boot if unset (see src/index.ts)
PORT=3000

# Optional — Vedika Panchang API. Unset = sandbox (fixed mock payload, no key needed).
# Set both to switch to production.
VEDIKA_API_KEY=
VEDIKA_API_BASE_URL=

# Optional — Meta WhatsApp Cloud API. Unset = /whatsapp/send returns 502 "not configured".
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Shared secret for the GET /whatsapp/webhook verify handshake — any string you choose,
# must match what's entered in the Meta App Dashboard's webhook config.
WHATSAPP_VERIFY_TOKEN=

# Required — Postgres (Drizzle ORM, code/lib/db). Phase 1 makes this a hard production
# requirement (smaran-prod/smaran-dev already provisioned).
DATABASE_URL=

# Required — Shared secret gating the GET /purohits/:phoneNumber inspection endpoint
INTERNAL_API_KEY=

# Optional — Nominatim Geocoding API base URL. Defaults to https://nominatim.openstreetmap.org if unset.
# NOMINATIM_BASE_URL=

# Optional — Sarvam Saaras v3 ASR (primary). Unset = ASR calls fail; set ASR_PROVIDER=openai to fall back.
SARVAM_API_KEY=
SARVAM_API_BASE_URL=

# Optional — OpenAI transcribe (ASR fallback, config-switchable).
OPENAI_API_KEY=

# Which AsrProvider implementation to use. Defaults to sarvam (D-01 primary).
ASR_PROVIDER=sarvam

# Extraction-model key(s) — exact var(s) depend on which model the §11 eval harness bake-off
# selects (Claude Haiku 4.5 / Gemini Flash / Sarvam-M). Do not pre-populate before the bake-off
# runs (D-02).
EXTRACTION_MODEL=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Optional — Sentry DSN for backend error aggregation. Unset = disabled (no-op).
SENTRY_DSN=

# Required in Production — WhatsApp App Secret for verifying webhook HMAC-SHA256 signature.
WHATSAPP_APP_SECRET=
SKIP_WEBHOOK_SIGNATURE_VERIFICATION=
