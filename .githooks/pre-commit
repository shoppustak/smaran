#!/usr/bin/env bash
# Blocks commits containing likely secrets (staged diff only). Install: git config core.hooksPath .githooks
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "warning: gitleaks not installed (brew install gitleaks) — skipping secret scan" >&2
  exit 0
fi

gitleaks protect --staged --redact --verbose
